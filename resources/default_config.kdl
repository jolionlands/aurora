// aurora default configuration
// Written to %APPDATA%\aurora\config.kdl on first run.
// Restart aurora after changing runtime settings.

log-level "info"

// ---------------------------------------------------------------------------
// Source folders — add as many as you like.
// ---------------------------------------------------------------------------
source {
    path "C:/Users/Public/Pictures"
    recursive true
    extensions "jpg,jpeg,png,gif,webp,bmp,tif,tiff,ico"
    min-width 1280
    min-height 720
}

// ---------------------------------------------------------------------------
// Schedule
// ---------------------------------------------------------------------------
schedule {
    mode "interval"          // "interval" | "at"
    interval-secs 1800       // 30 minutes
    // at "09:00"            // uncomment to use mode=at with fixed times
    // at "17:00"
    on-workspace-change false
    pause-when-fullscreen true
    pause-when-idle-secs 0   // 0 = never pause for idle
    min-repeat-window 20     // avoid repeating a photo within last N shown
}

// ---------------------------------------------------------------------------
// Transitions
// ---------------------------------------------------------------------------
transitions {
    enabled false
    duration-ms 800
    style "crossfade"        // crossfade | slide-left | slide-right | wipe-left
                             // wipe-right | dissolve | zoom-in | zoom-out | none
    renderer "auto"          // "gpu" | "cpu" | "auto"
}

// ---------------------------------------------------------------------------
// Per-monitor overrides  (optional — defaults apply when omitted)
// ---------------------------------------------------------------------------
// monitor "\\.\DISPLAY1\Monitor0" {
//     fit "fill"            // fill | contain | tile | center | stretch
// }

// ---------------------------------------------------------------------------
// Metrics  (Prometheus endpoint)
// ---------------------------------------------------------------------------
metrics {
    enabled false
    port 9876
}

// ---------------------------------------------------------------------------
// Decode cache
// ---------------------------------------------------------------------------
cache {
    decoded-mb 256
}
